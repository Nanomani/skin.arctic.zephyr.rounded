<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1154">
    <defaultcontrol>11</defaultcontrol>

    <onload>SetProperty(SetSettingsTypeSelected,$VAR[View_SettingsPerf_Selected],Home)</onload>
    <onunload>ClearProperty(SetSettingsTypeSelected,Home)</onunload>

    <controls>
        <include>Background_Overlay</include>

        <control type="group">
            <include content="Def_Dialog_Background">
                <param name="height" value="882" />
                <param name="width" value="1722" />
            </include>

            <include content="Def_Dialog_Header">
                <param name="label" value="10018" />
                <param name="icon" value="skinsettings" />
            </include>

            <control type="list" id="11">
                <include>Animation_Scrolltime_Views_List</include>

                <top>112</top>
                <left>16</left>
                <width>418</width>
                <height>700</height>

                <onup>11</onup>
                <ondown>11</ondown>
                <onleft>close</onleft>
                <onright>1773</onright>

                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>0</itemgap>

                <itemlayout width="418" height="70">
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>PanelWhite100</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>!String.IsEqual(Window(Home).property(SetSettingsTypeSelected),ListItem.Label)</visible>
                    </control>
                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>$VAR[Color_List_Item_Selected]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                        <visible>String.IsEqual(Window(Home).property(SetSettingsTypeSelected),ListItem.Label)</visible>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Black70" />
                        <param name="colordiffuse_on" value="$VAR[Color_List_Item_Selected]" />
                        <param name="visible" value="String.IsEqual(Window(Home).property(SetSettingsTypeSelected),ListItem.Label)" />
                    </include>
                </itemlayout>
                <focusedlayout width="418" height="70">

                    <!-- ITEM FOCUS GRADIENT -->

                    <include>Def_Focus_Item_Gradient</include>

                    <control type="label">
                        <left>30</left>
                        <width>310</width>
                        <height>70</height>
                        <font>Small</font>
                        <textcolor>Selected</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                    <include content="Def_Button_Radio">
                        <param name="colordiffuse_off" value="Selected" />
                        <param name="colordiffuse_on" value="Selected" />
                        <param name="visible" value="String.IsEqual(Window(Home).property(SetSettingsTypeSelected),ListItem.Label)" />
                    </include>
                </focusedlayout>

                <!-- PERFORMANCE -->

                <content>
                    <item id="1">
                        <label>$LOCALIZE[31610]</label>

                        <include>Def_Disable_All_TMDb_Helper_Services</include>
                        <include>Def_Performance_Value</include>
                        <include>Def_Settings_Clearlogo_Disable_All</include>

                        <onclick>Skin.SetString(settingstype,$LOCALIZE[31610])</onclick>
                        <onclick>SetProperty(reloadskin,1,Home)</onclick>
                        <onclick>close</onclick>
                    </item>

                    <!-- BALANCED - DEFAULT -->

                    <item id="2">
                        <label>$LOCALIZE[31611] ($LOCALIZE[571])</label>

                        <include>Def_Enable_All_TMDb_Helper_Services</include>
                        <include>Def_Settings_Clearlogo_Disable_All</include>
                        <include>Def_Settings_All_Default_Value</include>

                        <onclick>Skin.SetString(settingstype,$LOCALIZE[31611] ($LOCALIZE[571]))</onclick>
                        <include>Action_BuildTextures_Onclick</include>
                        <onclick>Close</onclick>
                    </item>

                    <!-- QUALITY -->

                    <item id="3">
                        <label>$LOCALIZE[31612]</label>

                        <include>Def_Enable_All_TMDb_Helper_Services</include>
                        <include>Def_Settings_All_Default_Value</include>
                        <include>Def_Settings_Clearlogo_Enable_All</include>

                        <onclick>Skin.SetString(settingstype,$LOCALIZE[31612])</onclick>
                        <include>Action_BuildTextures_Onclick</include>
                        <onclick>Close</onclick>
                    </item>
                </content>
            </control>

            <!-- LINE VERTICAL -->

            <include content="Def_Dialog_Line_Vertical"><param name="right" value="1272" /></include>

            <!-- VIEW TYPE ON RIGHT -->

            <include content="Def_Dialog_View_Type">
                <param name="texture" value="special://skin/extras/performance/$VAR[Def_Image_Settings_Performance].jpg" />
            </include>

            <!-- NUM ITEMS -->

            <include>Def_Dialog_Select_label_Num_Item</include>
        </control>
    </controls>
</window>
