<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1156">
    <defaultcontrol>11</defaultcontrol>

    <onload>SetProperty(SetSkinPresetColorSelected,$VAR[Label_Skin_Settings_Preset_Color_Selected],Home)</onload>
